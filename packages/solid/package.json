{
  "name": "@modyra/solid",
  "version": "0.3.0",
  "description": "Solid binding for the Modyra form engine — type-safe forms on Solid's native signals.",
  "keywords": [
    "solid",
    "solidjs",
    "forms",
    "typescript",
    "validation"
  ],
  "license": "MIT",
  "author": "Lorenzo Muscherà",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modyra/modyra.git",
    "directory": "packages/solid"
  },
  "bugs": {
    "url": "https://github.com/modyra/modyra/issues"
  },
  "homepage": "https://github.com/modyra/modyra#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --conditions=browser --test test/*.test.mjs"
  },
  "sideEffects": false,
  "dependencies": {
    "@modyra/core": "0.3.0",
    "@modyra/widgets": "0.3.0"
  },
  "peerDependencies": {
    "solid-js": ">=1.8.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
