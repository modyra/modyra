{
  "name": "@modyra/studio-codegen",
  "version": "0.0.0",
  "private": true,
  "description": "Modyra Studio: target plugin API (StudioTarget, lazy TargetManifest registry, Artifact) and a reusable conformance test suite every target must pass.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "sideEffects": false,
  "dependencies": {
    "@modyra/studio-model": "workspace:*"
  }
}
