{
    "name": "@modyra/styles",
    "version": "0.1.0",
    "description": "Framework-agnostic style themes for modyra components.",
    "license": "MIT",
    "author": "Lorenzo Muscherà",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/modyra/modyra.git",
        "directory": "packages/styles"
    },
    "bugs": {
        "url": "https://github.com/modyra/modyra/issues"
    },
    "homepage": "https://github.com/modyra/modyra#readme",
    "keywords": [
        "css",
        "styles",
        "theme",
        "design-system",
        "framework-agnostic"
    ],
    "scripts": {
        "build": "node build.mjs"
    },
    "exports": {
        "./default.css": {
            "default": "./dist/modyra.css"
        },
        "./material.css": {
            "default": "./dist/modyra-material.css"
        },
        "./ios.css": {
            "default": "./dist/modyra-ios.css"
        },
        "./ionic.css": {
            "default": "./dist/modyra-ionic.css"
        },
        "./base.css": {
            "default": "./dist/modyra-base.css"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "publishConfig": {
        "access": "public"
    }
}