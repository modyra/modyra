{
  "name": "@modyra/widgets",
  "version": "0.1.0",
  "description": "Headless widget controllers and universal interaction/accessibility contract for Modyra.",
  "license": "MIT",
  "author": "Lorenzo Muscherà",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modyra/modyra.git",
    "directory": "packages/widgets"
  },
  "bugs": {
    "url": "https://github.com/modyra/modyra/issues"
  },
  "homepage": "https://github.com/modyra/modyra#readme",
  "keywords": [
    "widgets",
    "headless",
    "accessibility",
    "typescript",
    "framework-agnostic"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "default": "./dist/contract.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "default": "./dist/commands.js"
    },
    "./ids": {
      "types": "./dist/ids.d.ts",
      "default": "./dist/ids.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.spec.mjs"
  },
  "sideEffects": false,
  "dependencies": {
    "@modyra/core": "0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
