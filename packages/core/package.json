  "license": "MIT",
  "author": "Lorenzo Muscher\u00e0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.personal/modyra/modyra.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/modyra/modyra/issues"
  },
  "homepage": "https://github.com/modyra/modyra#readme",
  "keywords": [
    "forms",
    "typescript",
    "signals",
    "validation",
    "framework-agnostic"
  ],
  "type": "module",
  "main": "./dist/index.js",
