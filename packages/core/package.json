{
  "name": "@modyra/core",
  "version": "0.3.0",
  "description": "Framework-agnostic type-safe form engine — typed field trees, sync/async/cross-field validation, drafts and undo/redo over a minimal reactive contract.",
  "license": "MIT",
  "author": "Lorenzo Muscherà",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modyra/modyra.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/modyra/modyra/issues"
  },
  "homepage": "https://github.com/modyra/modyra#readme",
  "keywords": [
    "forms",
    "typescript",
    "signals",
    "validation",
    "framework-agnostic"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./date-utils": {
      "types": "./dist/date-utils.d.ts",
      "default": "./dist/date-utils.js"
    },
    "./date-locale": {
      "types": "./dist/date-locale.d.ts",
      "default": "./dist/date-locale.js"
    },
    "./time-utils": {
      "types": "./dist/time-utils.d.ts",
      "default": "./dist/time-utils.js"
    },
    "./overlay-position": {
      "types": "./dist/overlay-position.d.ts",
      "default": "./dist/overlay-position.js"
    },
    "./options-utils": {
      "types": "./dist/options-utils.d.ts",
      "default": "./dist/options-utils.js"
    },
    "./serialize": {
      "types": "./dist/serialize.d.ts",
      "default": "./dist/serialize.js"
    },
    "./dynamic-config": {
      "types": "./dist/dynamic-config.d.ts",
      "default": "./dist/dynamic-config.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "default": "./dist/i18n.js"
    },
    "./keyboard": {
      "types": "./dist/keyboard.d.ts",
      "default": "./dist/keyboard.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "default": "./dist/devtools.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "default": "./dist/icons.js"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "default": "./dist/form.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "default": "./dist/validation.js"
    },
    "./datetime": {
      "types": "./dist/datetime.d.ts",
      "default": "./dist/datetime.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./localization": {
      "types": "./dist/localization.d.ts",
      "default": "./dist/localization.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.mjs"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}