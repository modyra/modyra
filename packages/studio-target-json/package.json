{
  "name": "@modyra/studio-target-json",
  "version": "0.0.0",
  "private": true,
  "description": "Modyra Studio: the Contract target scope (plan section 10) — exports project.json (raw StudioProject) and contract.json (compiled Contract v2).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "sideEffects": false,
  "dependencies": {
    "@modyra/studio-model": "workspace:*",
    "@modyra/studio-contract": "workspace:*",
    "@modyra/studio-codegen": "workspace:*"
  }
}
