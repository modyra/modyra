{
  "name": "@modyra/lit",
  "version": "0.2.0",
  "description": "Lit binding for the Modyra form engine — ReactiveController plus themable form elements.",
  "keywords": [
    "lit",
    "web-components",
    "forms",
    "typescript",
    "validation"
  ],
  "license": "MIT",
  "author": "Lorenzo Muscherà",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modyra/modyra.git",
    "directory": "packages/lit"
  },
  "bugs": {
    "url": "https://github.com/modyra/modyra/issues"
  },
  "homepage": "https://github.com/modyra/modyra#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "default": "./dist/adapter.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.mjs"
  },
  "sideEffects": false,
  "dependencies": {
    "@modyra/core": "0.2.0",
    "@modyra/widgets": "0.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "lit": ">=3.0.0"
  },
  "devDependencies": {
    "lit": "^3.0.0"
  }
}
