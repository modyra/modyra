---
// P12 route: /modyra/studio/changelog/ — condensed from the real,
// verified batch history this session tracked in
// .modyra/framework/STATUS.md (gitignored, not published). Each entry
// below reflects work that actually shipped with tests, not a roadmap.
import '../../../styles/custom.css';

const based = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;

const entries = [
  { phase: "P11", title: "Live preview, storage, import/export", desc: "A Preview tab builds a real running form from the project — values, validators, arrays, pending/canSubmit, a configurable server mock (succeed/fail/network-failure/timeout). Projects auto-save to IndexedDB and restore on reload; JSON import/export round-trips through the same loader that validates on load." },
  { phase: "P10", title: "React target", desc: "Generates a real useMdyForm() definition — the schema is wrapped in a thunk and the call sits inside an exported hook, matching the Rules of Hooks, not a bare module-scope form() like Core/Angular." },
  { phase: "P9", title: "Angular target", desc: "Generates a real mdyForm() definition via @modyra/angular/adapter. Verified byte-identical schema/validator output to the Core target once the factory call is normalized — proof the mapping logic is genuinely shared, not duplicated." },
  { phase: "P8", title: "Core target", desc: "The first target that emits real, runnable code: a createForm() definition, typed stub functions for every symbolic implementation reference, and a submit example. Verified by running the generated files through the real TypeScript compiler." },
  { phase: "P7", title: "Target platform", desc: "A lazy target registry and a conformance suite every target must pass — determinism, no project mutation, safe file paths, valid diagnostics. A target failure never corrupts the editor; a stale generation is discarded, never rendered." },
  { phase: "P6", title: "Diagnostics + Contract export", desc: "Compiles the project to the portable Dynamic Form Contract v2, strict-parsed through the real parser. A Diagnostics tab surfaces model and export issues together, with one-click fixes for the ones a single command can resolve." },
  { phase: "P5", title: "Validators", desc: "Field, array, cross-field/form, and server validators — dependencies, debounce/timeout, skip-when, AND/OR/NOT composition, all picked from dropdowns populated by the tree, never typed by path." },
  { phase: "P4", title: "Keyboard + accessibility", desc: "Every drag-and-drop action has a keyboard-only equivalent: pick up a node, arrow it around siblings or in/out of containers, drop it. Live region announcements for every action." },
  { phase: "P3–P2", title: "Canvas + commands", desc: "Pointer drag-and-drop over an invertible command engine — every mutation is a Command with a real inverse, so undo/redo covers the whole canvas." },
  { phase: "P1", title: "Model", desc: "The canonical project model: stable IDs, derived paths (never stored), normalize/serialize/migrate, structural validation on load." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Modyra Studio — changelog</title>
    <meta name="description" content="What has actually shipped in Modyra Studio, phase by phase." />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={based('')}>Modyra</a>
      <nav class="topnav">
        <a href={based('start-here/')}>Docs</a>
        <a href={based('pitch')}>Pitch deck</a>
        <a href={based('studio')}>Studio</a>
        <a href="https://github.com/modyra/modyra">GitHub</a>
      </nav>
    </header>

    <section class="hero">
      <p class="eyebrow">Modyra Studio · changelog</p>
      <h1>What has actually shipped</h1>
      <p class="lede">
        Studio is built phase by phase, each one gated on real tests before
        the next starts. This list reflects what is verified and running
        today, not a roadmap.
      </p>
    </section>

    <section class="log">
      {entries.map((e) => (
        <article class="entry">
          <div class="entry-phase">{e.phase}</div>
          <div class="entry-body">
            <h3>{e.title}</h3>
            <p class="desc">{e.desc}</p>
          </div>
        </article>
      ))}
    </section>

    <footer class="footer">
      <div class="link-row">
        <a href={based('studio')}>← Back to Studio</a>
        <a href={based('studio/app/')}>Launch Studio →</a>
        <a href="https://github.com/modyra/modyra">GitHub →</a>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: var(--mdy-night); --bg-card: #1c1e30; --fg: var(--mdy-cloud);
    --fg-muted: var(--mdy-slate); --border: #2c2f47; --mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg: var(--mdy-cloud); --bg-card: #ffffff; --fg: var(--mdy-night); --fg-muted: #52577a; --border: #e1e4ef; }
  }
  :root[data-theme='dark'] { --bg: var(--mdy-night); --bg-card: #1c1e30; --fg: var(--mdy-cloud); --fg-muted: var(--mdy-slate); --border: #2c2f47; }
  :root[data-theme='light'] { --bg: var(--mdy-cloud); --bg-card: #ffffff; --fg: var(--mdy-night); --fg-muted: #52577a; --border: #e1e4ef; }

  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); font-family: 'Satoshi', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
  h1, h3 { text-wrap: balance; margin: 0; }

  .topbar { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem clamp(1.5rem, 6vw, 4rem); border-bottom: 1px solid var(--border); }
  .brand { font-weight: 900; font-size: 1.1rem; color: var(--fg); text-decoration: none; letter-spacing: -0.01em; }
  .topnav { display: flex; gap: 1.75rem; }
  .topnav a { color: var(--fg-muted); text-decoration: none; font-size: 0.92rem; }
  .topnav a:hover, .topnav a:focus-visible { color: var(--fg); }

  .eyebrow { font-family: var(--mono); font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-muted); margin: 0 0 1.25rem; display: flex; align-items: center; gap: 0.6rem; }
  .eyebrow::before { content: ''; width: 1.5rem; height: 2px; background: var(--mdy-gradient-brand); display: inline-block; }

  .hero { padding: clamp(3rem, 8vw, 5rem) clamp(1.5rem, 8vw, 8rem) clamp(2rem, 5vw, 3rem); }
  .hero h1 { font-weight: 900; font-size: clamp(2rem, 5vw, 3.2rem); line-height: 1.08; letter-spacing: -0.02em; max-width: 20ch; }
  .lede { font-size: clamp(1rem, 1.5vw, 1.2rem); line-height: 1.55; color: var(--fg-muted); max-width: 62ch; margin: 1.5rem 0 0; }

  .log { padding: 0 clamp(1.5rem, 8vw, 8rem) clamp(3rem, 6vw, 5rem); display: grid; gap: 1rem; }
  .entry { display: grid; grid-template-columns: 5rem 1fr; gap: 1.25rem; border: 1px solid var(--border); border-radius: 0.6rem; padding: 1.25rem; background: var(--bg-card); }
  .entry-phase { font-family: var(--mono); font-weight: 700; color: var(--mdy-indigo); font-size: 0.9rem; }
  .entry-body h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .entry-body .desc { font-size: 0.9rem; color: var(--fg-muted); line-height: 1.55; margin: 0; }
  @media (max-width: 640px) { .entry { grid-template-columns: 1fr; } }

  .footer { padding: 2.5rem clamp(1.5rem, 8vw, 8rem) 3rem; border-top: 1px solid var(--border); }
  .link-row { display: flex; gap: 2rem; flex-wrap: wrap; }
  .link-row a { color: var(--fg-muted); text-decoration: none; font-size: 0.9rem; border-bottom: 1px solid var(--border); padding-bottom: 0.2rem; transition: border-color 0.15s ease; }
  .link-row a:hover, .link-row a:focus-visible { color: var(--fg); border-color: var(--mdy-indigo); }
</style>
