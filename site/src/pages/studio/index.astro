---
// P12: apps/studio/dist is copied into public/studio-app/ by
// scripts/copy-studio-app.mjs (run via `npm run sync:studio-app` at the
// repo root, before this site's own isolated build) — see
// .modyra/framework/STATUS.md for why this is a static asset reference
// and not a Vite import of @modyra/studio-ui from source: site/ installs
// via its own package-lock.json, outside the pnpm workspace, and never
// resolves workspace packages.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Modyra Studio</title>
    <meta name="description" content="Local-first visual form editor." />
    <link rel="stylesheet" href={`${base}/studio-app/studio.css`} />
  </head>
  <body style="margin:0">
    <div data-modyra-studio></div>
    <script type="module" src={`${base}/studio-app/studio.js`}></script>
  </body>
</html>
