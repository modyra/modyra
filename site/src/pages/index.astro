---
// Hand-authored marketing splash for the site root ("/"). Deliberately
// outside the Starlight content collection (docs/**/*.md ->
// site/src/content/docs/, regenerated by scripts/sync-docs-site.mjs) --
// same pattern as pitch.astro, for the same reason: this page is never
// synced or wiped by that script. docs/README.md (the real documentation
// index) now lives at /start-here/ instead of "/" -- see that script's
// README-routing comment.
import '../styles/custom.css';

// BASE_URL isn't guaranteed a trailing slash -- normalize the same way
// astro.config.mjs's own `based()` helper does.
const based = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;

const frameworks = [
  { name: "Angular", href: "examples/angular/" },
  { name: "React", href: "examples/react/" },
  { name: "Vue", href: "examples/vue/" },
  { name: "Lit", href: "examples/lit/" },
  { name: "Solid", href: "examples/solid/" },
  { name: "Preact", href: "examples/preact/" },
  { name: "Svelte", href: "examples/svelte/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Modyra — model once, render anywhere</title>
    <meta
      name="description"
      content="A framework-agnostic, type-safe form engine for TypeScript. One engine, seven native adapters (Angular, React, Vue, Lit, Solid, Preact, Svelte) — typed forms, drafts, undo/redo, async and server validation, built in."
    />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={based('')}>Modyra</a>
      <nav class="topnav">
        <a href={based('start-here/')}>Docs</a>
        <a href={based('pitch')}>Pitch deck</a>
        <a href={based('studio')}>Studio</a>
        <a href="https://github.com/modyra/modyra">GitHub</a>
      </nav>
    </header>

    <section class="hero">
      <p class="eyebrow">Modyra · form engine for TypeScript</p>
      <h1>
        Model once.<br /><span class="gradient-text">Render anywhere.</span>
      </h1>
      <p class="lede">
        <code class="mono">@modyra/core</code> is a form engine that has never
        heard of a UI framework — it runs the same in Node, a CLI, a worker, or
        a unit test. Seven thin adapters (Angular, React, Vue, Lit, Solid,
        Preact, Svelte) bind that one engine to each framework's own
        reactivity, natively.
      </p>
      <div class="hero-install">
        <span class="prompt">$</span> npm install @modyra/core @modyra/react
      </div>
      <div class="hero-ctas">
        <a class="btn btn-primary" href={based('start-here/')}>Get started →</a>
        <a class="btn btn-secondary" href="https://stackblitz.com/github/modyra/modyra/tree/main/examples/stackblitz-react">Try it live →</a>
        <a class="btn btn-secondary" href={based('pitch')}>See the numbers →</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="num tabular gradient-text">#1</div>
          <div class="label">realistic bundle size</div>
        </div>
        <div class="hero-stat">
          <div class="num tabular">7</div>
          <div class="label">framework adapters</div>
        </div>
        <div class="hero-stat">
          <div class="num tabular">0</div>
          <div class="label">runtime dependencies</div>
        </div>
        <div class="hero-stat">
          <div class="num tabular">0.4.0</div>
          <div class="label">on npm now</div>
        </div>
      </div>
    </section>

    <section class="why">
      <div class="why-grid">
        <div class="why-cell">
          <p class="eyebrow">Typed, not stringly-keyed</p>
          <h3>Typos don't compile</h3>
          <p class="desc">
            <code class="mono">form.f.email</code> is a real, typed field
            handle inferred from your schema — not a string key that fails at
            runtime.
          </p>
        </div>
        <div class="why-cell">
          <p class="eyebrow">Batteries in the engine</p>
          <h3>Not a second library away</h3>
          <p class="desc">
            Drafts, undo/redo, wizard gating and injection prevention ship
            inside the core. Async validation gets debounce, cancellation and
            cross-field rules by default.
          </p>
        </div>
        <div class="why-cell">
          <p class="eyebrow">One engine, native everywhere</p>
          <h3>No adapter reimplements form logic</h3>
          <p class="desc">
            Angular gets real signals, Solid gets real signals, Vue gets real
            reactivity. Every adapter just wires signals to a render — the
            same tested logic runs underneath all seven.
          </p>
        </div>
      </div>
    </section>

    <section class="frameworks">
      <p class="eyebrow">Pick your framework</p>
      <h2>The same checkout form, seven times</h2>
      <p class="lede">
        Nested groups, a typed array of line items, a coupon checked
        server-side — implemented end to end in each binding.
      </p>
      <div class="fw-row">
        {frameworks.map((f) => (
          <a class="fw-chip" href={based(f.href)}>{f.name} →</a>
        ))}
      </div>
    </section>

    <footer class="footer">
      <div class="link-row">
        <a href={based('start-here/')}>Full documentation →</a>
        <a href={based('pitch')}>The measured pitch →</a>
        <a href={based('guides/comparison-form-libraries/')}>How we measured it →</a>
        <a href="https://github.com/modyra/modyra">GitHub →</a>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: var(--mdy-night);
    --bg-card: #1c1e30;
    --fg: var(--mdy-cloud);
    --fg-muted: var(--mdy-slate);
    --border: #2c2f47;
    --accent-strong: #c8c3ff;
    --mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root {
      --bg: var(--mdy-cloud);
      --bg-card: #ffffff;
      --fg: var(--mdy-night);
      --fg-muted: #52577a;
      --border: #e1e4ef;
      --accent-strong: #4a3fd6;
    }
  }
  :root[data-theme='dark'] {
    --bg: var(--mdy-night); --bg-card: #1c1e30; --fg: var(--mdy-cloud);
    --fg-muted: var(--mdy-slate); --border: #2c2f47; --accent-strong: #c8c3ff;
  }
  :root[data-theme='light'] {
    --bg: var(--mdy-cloud); --bg-card: #ffffff; --fg: var(--mdy-night);
    --fg-muted: #52577a; --border: #e1e4ef; --accent-strong: #4a3fd6;
  }

  html, body {
    margin: 0; padding: 0; background: var(--bg); color: var(--fg);
    font-family: 'Satoshi', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  ::selection { background: var(--mdy-indigo); color: white; }
  code, .mono { font-family: var(--mono); }
  .tabular { font-variant-numeric: tabular-nums; }
  h1, h2, h3 { text-wrap: balance; margin: 0; }

  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem clamp(1.5rem, 6vw, 4rem);
    border-bottom: 1px solid var(--border);
  }
  .brand { font-weight: 900; font-size: 1.1rem; color: var(--fg); text-decoration: none; letter-spacing: -0.01em; }
  .topnav { display: flex; gap: 1.75rem; }
  .topnav a { color: var(--fg-muted); text-decoration: none; font-size: 0.92rem; }
  .topnav a:hover, .topnav a:focus-visible { color: var(--fg); }

  .eyebrow {
    font-family: var(--mono); font-size: 0.8rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--fg-muted); margin: 0 0 1.25rem;
    display: flex; align-items: center; gap: 0.6rem;
  }
  .eyebrow::before {
    content: ''; width: 1.5rem; height: 2px;
    background: var(--mdy-gradient-brand); display: inline-block;
  }

  .hero {
    padding: clamp(3rem, 8vw, 7rem) clamp(1.5rem, 8vw, 8rem) clamp(2.5rem, 6vw, 5rem);
    background:
      radial-gradient(ellipse 80% 60% at 15% -10%, color-mix(in srgb, var(--mdy-indigo) 22%, transparent), transparent),
      radial-gradient(ellipse 60% 50% at 90% 10%, color-mix(in srgb, var(--mdy-coral) 14%, transparent), transparent);
  }
  .hero h1 {
    font-weight: 900; font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 1.03; letter-spacing: -0.02em; max-width: 16ch;
  }
  .gradient-text {
    background: var(--mdy-gradient-brand);
    background-clip: text; -webkit-background-clip: text; color: transparent;
  }
  .lede {
    font-size: clamp(1.05rem, 1.6vw, 1.3rem); line-height: 1.55;
    color: var(--fg-muted); max-width: 60ch; margin: 1.5rem 0 0;
  }
  .hero-install {
    margin-top: 2rem; display: inline-flex; align-items: center; gap: 0.75rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 0.6rem; padding: 0.85rem 1.25rem;
    font-family: var(--mono); font-size: 0.95rem; width: fit-content;
  }
  .hero-install .prompt { color: var(--fg-muted); }

  .hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
  .btn {
    display: inline-flex; align-items: center; padding: 0.75rem 1.4rem;
    border-radius: 0.6rem; font-weight: 600; font-size: 0.95rem;
    text-decoration: none; transition: opacity 0.15s ease, border-color 0.15s ease;
  }
  .btn-primary { background: var(--mdy-gradient-brand); color: #fff; }
  .btn-primary:hover, .btn-primary:focus-visible { opacity: 0.9; }
  .btn-secondary { border: 1px solid var(--border); color: var(--fg); background: var(--bg-card); }
  .btn-secondary:hover, .btn-secondary:focus-visible { border-color: var(--mdy-indigo); }
  .btn:focus-visible { outline: 2px solid var(--mdy-indigo); outline-offset: 3px; }

  .hero-stats { display: flex; gap: clamp(1.5rem, 4vw, 3.5rem); margin-top: 3rem; flex-wrap: wrap; }
  .hero-stat .num { font-weight: 900; font-size: clamp(1.5rem, 2.6vw, 2.2rem); line-height: 1; }
  .hero-stat .label { font-size: 0.82rem; color: var(--fg-muted); margin-top: 0.4rem; }

  .why { padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 8vw, 8rem); border-top: 1px solid var(--border); }
  .why-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 2.5rem;
  }
  .why-cell h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; }
  .why-cell .desc { font-size: 0.92rem; color: var(--fg-muted); line-height: 1.55; max-width: 32ch; }

  .frameworks {
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 8vw, 8rem);
    border-top: 1px solid var(--border);
  }
  .frameworks h2 {
    font-weight: 700; font-size: clamp(1.6rem, 3.2vw, 2.3rem);
    line-height: 1.1; letter-spacing: -0.01em; max-width: 20ch; margin-bottom: 0.75rem;
  }
  .fw-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 2rem; }
  .fw-chip {
    font-family: var(--mono); font-size: 0.88rem; padding: 0.6rem 1.1rem;
    border: 1px solid var(--border); border-radius: 999px; color: var(--fg);
    background: var(--bg-card); text-decoration: none; transition: border-color 0.15s ease;
  }
  .fw-chip:hover, .fw-chip:focus-visible { border-color: var(--mdy-indigo); }

  .footer { padding: 2.5rem clamp(1.5rem, 8vw, 8rem) 3rem; border-top: 1px solid var(--border); }
  .link-row { display: flex; gap: 2rem; flex-wrap: wrap; }
  .link-row a {
    color: var(--fg-muted); text-decoration: none; font-size: 0.9rem;
    border-bottom: 1px solid var(--border); padding-bottom: 0.2rem; transition: border-color 0.15s ease;
  }
  .link-row a:hover, .link-row a:focus-visible { color: var(--fg); border-color: var(--mdy-indigo); }
</style>
