{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "modyra": {
      "projectType": "library",
      "root": "packages/angular",
      "sourceRoot": "packages/angular/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "packages/angular/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "packages/angular/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:jest",
          "options": {
            "tsConfig": "packages/angular/tsconfig.spec.json",
            "polyfills": [
              "@angular/compiler"
            ],
            "exclude": [
              "**/benchmarks.spec.ts",
              "e2e/**/*"
            ]
          }
        },
        "test-perf": {
          "builder": "@angular-devkit/build-angular:jest",
          "options": {
            "tsConfig": "packages/angular/tsconfig.spec.json",
            "polyfills": [
              "@angular/compiler"
            ],
            "include": [
              "**/benchmarks.spec.ts"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "packages/angular/**/*.ts",
              "packages/angular/**/*.html"
            ],
            "eslintConfig": "packages/angular/eslint.config.js"
          }
        }
      }
    },
    "demo": {
      "projectType": "application",
      "root": "examples/angular",
      "sourceRoot": "examples/angular/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/demo",
            "index": "examples/angular/src/index.html",
            "browser": "examples/angular/src/main.ts",
            "tsConfig": "examples/angular/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "packages/styles/dist",
                "output": "styles"
              }
            ],
            "styles": [
              "packages/styles/dist/modyra-base.css",
              "examples/angular/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "demo:build:production"
            },
            "development": {
              "buildTarget": "demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "examples/angular/**/*.ts",
              "examples/angular/**/*.html"
            ],
            "eslintConfig": "examples/angular/eslint.config.js"
          }
        }
      }
    },
    "bundle-test": {
      "projectType": "application",
      "root": "projects/bundle-test",
      "sourceRoot": "projects/bundle-test/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/bundle-test",
            "index": "projects/bundle-test/src/index.html",
            "browser": "projects/bundle-test/src/main.ts",
            "tsConfig": "projects/bundle-test/tsconfig.app.json",
            "polyfills": []
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "none",
              "budgets": []
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  }
}
