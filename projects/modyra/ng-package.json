{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    {
      "input": "./src/styles",
      "glob": "**/*.css",
      "output": "./styles"
    },
    {
      "input": "./src/styles",
      "glob": "**/*.scss",
      "output": "./styles"
    },
    {
      "input": "./src/styles",
      "glob": "**/*.svg",
      "output": "./styles"
    }
  ],
  "deleteDestPath": false
}